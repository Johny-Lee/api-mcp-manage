{
  "name": "@api-mcp/desktop",
  "version": "1.3.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@api-mcp/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.api-mcp.manager",
    "productName": "API MCP Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
